# ============================================================
# ROS2 빌드 산출물
# ============================================================
# colcon build 결과물 → 각자 로컬에서 빌드하므로 공유 불필요
build/
install/
log/

# ============================================================
# ROS2 패키지 내부 빌드 파일
# ============================================================
*.egg-info/
__pycache__/
*.pyc
*.pyo

# ============================================================
# Docker 관련
# ============================================================
# 환경변수 파일 (API 키, 비밀번호 등 민감 정보 포함 가능)
.env
.env.local
.env.*.local

# ============================================================
# VSCode
# ============================================================
# 팀 공통 설정(.devcontainer)은 올리고, 개인 설정은 제외
.vscode/settings.json
.vscode/launch.json
.vscode/tasks.json
# 단, .devcontainer/ 는 제외하지 않음 (팀 공유 대상)

# ============================================================
# OS 생성 파일
# ============================================================
# macOS
.DS_Store
.AppleDouble
.LSOverride

# Windows
Thumbs.db
ehthumbs.db
Desktop.ini

# Linux
*~

# ============================================================
# 에디터/IDE
# ============================================================
*.swp
*.swo
*.orig
.idea/

# ============================================================
# Python
# ============================================================
*.pyo
*.pyd
.Python
pip-log.txt
pip-delete-this-directory.txt

# ============================================================
# C++ 컴파일 산출물
# ============================================================
*.o
*.a
*.so
*.out

# ============================================================
# 로그 및 임시 파일
# ============================================================
*.log
*.tmp
*.bak
ros2bag_*

# Generated by dynamic reconfigure
*.cfgc
/cfg/cpp/
/cfg/*.py

# Ignore generated docs
*.dox
*.wikidoc

# eclipse stuff
.project
.cproject

# qcreator stuff
CMakeLists.txt.user

srv/_*.py
*.pcd
*.pyc
qtcreator-*
*.user

/planning/cfg
/planning/docs
/planning/src

*~

# Emacs
.#*

# Catkin custom files
CATKIN_IGNORE
